# GeoFloodPredict Configuration

# API
DEBUG=false
API_TITLE=GeoFloodPredict
API_VERSION=0.1.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/geofloodpredict
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=geofloodpredict

# Logging
LOG_LEVEL=INFO

# Data & Models
DATA_DIR=data
MODELS_DIR=models
